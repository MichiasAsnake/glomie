    },
    {
      "type": "header",
      "content": "Item 2"
    },
    {
      "type": "select",
      "id": "item_2_icon",
      "label": "Icon",
      "options": [
        { "value": "lock", "label": "Lock" },
        { "value": "truck", "label": "Truck" },
        { "value": "return", "label": "Returns" },
        { "value": "plane", "label": "Shipping" },
        { "value": "box", "label": "Package" }
      ],
      "default": "truck"
    },
    {
      "type": "text",
      "id": "item_2_text",
      "label": "Text",
      "default": "Ships in 3-5 business days"
    },
    {
      "type": "header",
      "content": "Item 3"
    },
    {
      "type": "select",
      "id": "item_3_icon",
      "label": "Icon",
      "options": [
        { "value": "lock", "label": "Lock" },
        { "value": "truck", "label": "Truck" },
        { "value": "return", "label": "Returns" },
        { "value": "plane", "label": "Shipping" },
