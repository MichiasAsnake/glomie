{% style %}
  .hero__promo-box {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    border-radius: var(--menu-image-border-radius, 8px);
    overflow: hidden;
    text-align: center;
    padding: 2rem;
    width: 100%;
    min-height: 250px;
  }

  .hero__promo-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .hero__promo-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
    width: 100%;
  }

  .hero__promo-heading {
    margin: 0;
    font-size: 1.5rem;
  }

  .hero__promo-text {
    font-size: 1rem;
  }

  .hero__promo-button {
    margin-top: 0.5rem;
  }

  .hero__promo-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }
{% endstyle %}

{% style %}
  .hero__promo-box-{{ block.id }} {
    justify-content: {% if block.settings.vertical_alignment == 'top' %}flex-start{% elsif block.settings.vertical_alignment == 'bottom' %}flex-end{% else %}center{% endif %};
  }
  
  .hero__promo-box-{{ block.id }} .hero__promo-overlay {
    background-color: {{ block.settings.background_color | default: 'transparent' }};
    opacity: {{ block.settings.background_opacity | divided_by: 100.0 }};
  }

  .hero__promo-box-{{ block.id }} .hero__promo-content {
    align-items: {% if block.settings.horizontal_alignment == 'left' %}flex-start{% elsif block.settings.horizontal_alignment == 'right' %}flex-end{% else %}center{% endif %};
    text-align: {{ block.settings.horizontal_alignment }};
  }
{% endstyle %}

{% assign promo_bg = block.settings.background_image %}
<span
  class="hero__promo-box color-{{ block.settings.color_scheme }} hero__promo-box-{{ block.id }}"
  {{ block.shopify_attributes }}
>
  {% if promo_bg != blank %}
    {{ promo_bg | image_url: width: 800 | image_tag: alt: promo_bg.alt, class: 'hero__promo-bg' }}
  {% endif %}
  <div class="hero__promo-overlay"></div>
  
  <div class="hero__promo-content">
    {% if block.settings.heading != blank %}
      <h3 class="hero__promo-heading">{{ block.settings.heading }}</h3>
    {% endif %}
    {% if block.settings.text != blank %}
      <div class="hero__promo-text richtext">{{ block.settings.text }}</div>
    {% endif %}
    {% if block.settings.button_label != blank and block.settings.button_link != blank %}
      <a href="{{ block.settings.button_link }}" class="button button--primary hero__promo-button">
        {{ block.settings.button_label }}
      </a>
    {% endif %}
  </div>
</span>

{% schema %}
{
  "name": "Promo Box",
  "tag": null,
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "background_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Background Opacity",
      "default": 0
    },
    {
      "type": "select",
      "id": "horizontal_alignment",
      "label": "Horizontal Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "vertical_alignment",
      "label": "Vertical Alignment",
      "options": [
        { "value": "top", "label": "Top" },
        { "value": "center", "label": "Center" },
        { "value": "bottom", "label": "Bottom" }
      ],
      "default": "center"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Special Offer"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Description of the offer goes here.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "primary"
    }
  ],
  "presets": [
    {
      "name": "Promo Box",
      "category": "Custom Content"
    }
  ]
}
{% endschema %}
