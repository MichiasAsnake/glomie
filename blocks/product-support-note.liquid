{% assign block_settings = block.settings %}

{% capture note_content %}
  {% if block_settings.icon != 'none' %}
    <span class="product-support-note__icon" aria-hidden="true">
      <svg
        class="product-support-note__icon-svg"
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 20 20"
        width="20"
        height="20"
      >
        {% render 'icon', icon: block_settings.icon %}
      </svg>
    </span>
  {% endif %}

  <span class="product-support-note__text">{{ block_settings.text }}</span>
{% endcapture %}

<div
  class="product-support-note product-support-note--{{ block.id }} spacing-style"
  style="{% render 'spacing-style', settings: block_settings %} --product-support-note-alignment: {{ block_settings.alignment }};"
  {{ block.shopify_attributes }}
>
  {% if block_settings.link != blank %}
    <a
      href="{{ block_settings.link }}"
      class="product-support-note__link"
      {% if block_settings.open_in_new_tab %}
        target="_blank" rel="noopener"
      {% endif %}
    >
      {{ note_content }}
    </a>
  {% else %}
    {{ note_content }}
  {% endif %}
</div>

{% stylesheet %}
  .product-support-note {
    display: flex;
    justify-content: var(--product-support-note-alignment, flex-start);
    width: 100%;
  }

  .product-support-note__link,
  .product-support-note > .product-support-note__icon,
  .product-support-note > .product-support-note__text,
  .product-support-note {
    color: var(--color-foreground);
  }

  .product-support-note__link,
  .product-support-note > .product-support-note__text {
    text-decoration: none;
  }

  .product-support-note__link,
  .product-support-note {
    align-items: center;
    gap: 10px;
    font-size: 14px;
    line-height: 1.5;
  }

  .product-support-note__icon {
    display: inline-flex;
    flex: 0 0 auto;
    width: 18px;
    height: 18px;
  }

  .product-support-note__icon-svg {
    width: 100%;
    height: 100%;
  }

  .product-support-note__text {
    font-weight: 500;
  }

  .product-support-note__link:hover {
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .product-support-note[style*='--product-support-note-alignment: center'] .product-support-note__link,
  .product-support-note[style*='--product-support-note-alignment: center'] {
    justify-content: center;
    text-align: center;
  }

  .product-support-note[style*='--product-support-note-alignment: flex-end'] .product-support-note__link,
  .product-support-note[style*='--product-support-note-alignment: flex-end'] {
    justify-content: flex-end;
    text-align: right;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Product support note",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "30-day hassle-free returns"
    },
    {
      "type": "select",
      "id": "icon",
      "label": "Icon",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "lock", "label": "Lock" },
        { "value": "plane", "label": "Shipping" },
        { "value": "return", "label": "Returns" },
        { "value": "box", "label": "Package" }
      ],
      "default": "none"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "options": [
        { "value": "flex-start", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    },
    {
      "type": "checkbox",
      "id": "open_in_new_tab",
      "label": "Open link in new tab",
      "default": false,
      "visible_if": "{{ block.settings.link != blank }}"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 4
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ]
}
{% endschema %}
